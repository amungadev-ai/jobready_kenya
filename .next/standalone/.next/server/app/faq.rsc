9:["$","div",null,{"className":"mx-auto max-w-3xl space-y-10","children":[["$","section","Getting Started",{"children":[["$","div",null,{"className":"mb-4 flex items-center gap-3","children":[["$","div",null,{"className":"h-1 w-8 rounded-full bg-emerald-600"}],["$","h2",null,{"className":"text-xl font-bold text-gray-900","children":"Getting Started"}]]}],["$","div",null,{"className":"rounded-xl border border-gray-200/60 bg-white/70 p-6 backdrop-blur-sm sm:p-8","children":["$","$L12",null,{"type":"single","collapsible":true,"className":"w-full","children":[["$","$L13","0",{"value":"Getting Started-0","children":[["$","$L14",null,{"className":"text-left text-gray-800 hover:no-underline","children":"How do I apply for a job on JOBR?"}],["$","$L15",null,{"className":"leading-relaxed text-gray-600","children":"Applying for a job is simple. Browse or search for a job listing that interests you, click on it to view the full details, and then click the \"Apply\" button. Depending on the listing, you may be directed to apply through the employer's website, or you can apply directly on JOBR by submitting your CV and cover letter. Make sure your profile is up to date with your latest skills and experience before applying."}]]}],["$","$L13","1",{"value":"Getting Started-1","children":[["$","$L14",null,{"className":"text-left text-gray-800 hover:no-underline","children":"Are all jobs listed on JOBR verified?"}],["$","$L15",null,{"className":"leading-relaxed text-gray-600","children":"Yes. Every job listing on JOBR Kenya goes through a verification process before it is published. Our moderation team reviews each posting to confirm the employer's legitimacy, job details accuracy, and compliance with Kenyan labour laws. While we make every effort to ensure authenticity, we also encourage job seekers to independently verify employer details before sharing sensitive personal information."}]]}],["$","$L13","2",{"value":"Getting Started-2","children":[["$","$L14",null,{"className":"text-left text-gray-800 hover:no-underline","children":"Is JOBR free for job seekers?"}],["$","$L15",null,{"className":"leading-relaxed text-gray-600","children":"Absolutely. JOBR Kenya is completely free for job seekers. You can create an account, browse listings, apply for jobs, set up alerts, and upload your CV at no cost. We believe every Kenyan should have access to employment opportunities without financial barriers."}]]}]]}]}]]}],["$","section","Job Search & Alerts",{"children":[["$","div",null,{"className":"mb-4 flex items-center gap-3","children":[["$","div",null,{"className":"h-1 w-8 rounded-full bg-emerald-600"}],["$","h2",null,{"className":"text-xl font-bold text-gray-900","children":"Job Search & Alerts"}]]}],["$","div",null,{"className":"rounded-xl border border-gray-200/60 bg-white/70 p-6 backdrop-blur-sm sm:p-8","children":["$","$L12",null,{"type":"single","collapsible":true,"className":"w-full","children":[["$","$L13","0",{"value":"Job Search & Alerts-0","children":[["$","$L14",null,{"className":"text-left text-gray-800 hover:no-underline","children":"How do I search for jobs in my county?"}],["$","$L15",null,{"className":"leading-relaxed text-gray-600","children":"You can filter jobs by county in several ways. Use the county dropdown filter on the jobs page, browse our \"Jobs by County\" directory, or simply type your county name into the search bar (e.g., \"jobs in Mombasa\"). JOBR covers all 47 Kenyan counties, so you can find opportunities no matter where you are. You can also save your preferred county in your profile for faster future searches."}]]}],["$","$L13","1",{"value":"Job Search & Alerts-1","children":[["$","$L14",null,{"className":"text-left text-gray-800 hover:no-underline","children":"How do I create a job alert?"}],["$","$L15",null,{"className":"leading-relaxed text-gray-600","children":"To create a job alert, click on the \"Job Alerts\" section in your profile dashboard. Enter your preferred job title, category, location (county or city), and employment type. You can create multiple alerts for different preferences. Whenever new jobs matching your criteria are posted, you'll receive an email notification so you never miss an opportunity."}]]}],"$L16"]}]}]]}],"$L17","$L18"]}]
