 flex-wrap items-center gap-4 text-sm text-gray-500","children":[["$","span",null,{"className":"flex items-center gap-1.5","children":["$L3","JOBR Kenya Editorial Team"]}],"$L4","$L5"]}],"$L6","$L7"]}],"$L8"]}],"$L9"]}]]}],null,"$La"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"8nokA9daX44KZGfN1jVss"}
