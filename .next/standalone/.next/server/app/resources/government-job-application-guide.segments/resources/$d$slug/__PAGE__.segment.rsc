","h4",null,{"className":"mt-2 text-sm font-bold leading-snug text-gray-900 transition group-hover:text-emerald-600","children":"Interview Preparation Guide: What Kenyan Employers Really Ask"}],["$","p",null,{"className":"mt-1 text-xs text-gray-400","children":["7 min read"," · ","28 December 2025"]}]]}]]}]]}]}]
