["$","span",null,{"className":"flex items-center gap-1.5","children":[["$","svg",null,{"xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-user h-4 w-4","aria-hidden":"true","children":["$L3","$L4","$undefined"]}],"JOBR Kenya Editorial Team"]}],"$L5","$L6"]}],"$L7","$L8"]}],"$L9"]}],"$La"]}]]}],null,"$Lb"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"t_WP6D9YsDHjivvpkSTjR"}
