xt-gray-500","children":[["$","span",null,{"className":"flex items-center gap-1.5","children":[["$","svg",null,{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-user h-4 w-4","aria-hidden":"true","children":["$L14","$L15","$undefined"]}],"JOBR Kenya Editorial Team"]}],"$L16","$L17"]}],"$L18","$L19"]}],"$L1a"]}],"$L1b"]}]]}]
