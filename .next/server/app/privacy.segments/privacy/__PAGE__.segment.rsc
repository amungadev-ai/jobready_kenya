a:["$","section",null,{"children":[["$","h2",null,{"className":"text-xl font-bold text-gray-900","children":"6. Data Security"}],["$","p",null,{"className":"mt-3 leading-relaxed text-gray-600","children":"We implement industry-standard security measures to protect your personal information, including SSL encryption, secure server infrastructure, access controls, and regular security audits. However, no method of transmission over the internet is 100% secure, and we cannot guarantee absolute security."}]]}]
b:["$","section",null,{"children":[["$","h2",null,{"className":"text-xl font-bold text-gray-900","children":"7. Your Rights"}],["$","p",null,{"className":"mt-3 leading-relaxed text-gray-600","children":"Under the Kenya Data Protection Act, 2019, you have the following rights:"}],["$","ul",null,{"className":"mt-2 list-disc space-y-1 pl-6 text-gray-600","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Right of Access:"}]," Request a copy of the personal data we hold about you."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Rectification:"}]," Request correction of inaccurate or incomplete data."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Erasure:"}]," Request deletion of your personal data, subject to legal obligations."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Restrict Processing:"}]," Request limitation of how your data is processed."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Data Portability:"}]," Request your data in a machine-readable format."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Object:"}]," Object to processing of your data for direct marketing purposes."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Right to Withdraw Consent:"}]," Withdraw any consent you have previously given at any time."]}]]}],["$","p",null,{"className":"mt-3 leading-relaxed text-gray-600","children":["To exercise any of these rights, please contact us at"," ",["$","a",null,{"href":"mailto:hello@jobr.co.ke","className":"font-medium text-emerald-600 underline","children":"hello@jobr.co.ke"}],". We will respond to your request within 30 days as required by law."]}]]}]
c:["$","section",null,{"children":[["$","h2",null,{"className":"text-xl font-bold text-gray-900","children":"8. Data Retention"}],["$","p",null,{"className":"mt-3 leading-relaxed text-gray-600","children":"We retain your personal data only for as long as necessary to fulfil the purposes outlined in this policy:"}],["$","ul",null,{"className":"mt-2 list-disc space-y-1 pl-6 text-gray-600","children":[["$","li",null,{"children":[["$","strong",null,{"children":"Active accounts:"}]," Data is retained for the duration of your account activity."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Inactive accounts:"}]," Accounts inactive for 24+ months may be deactivated and data anonymised."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Applications:"}]," Job application data is retained for 12 months after the application deadline."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Analytics data:"}]," Anonymised usage data may be retained for up to 3 years."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Legal holds:"}]," Data may be retained longer if required by law or for dispute resolution."]}]]}]]}]
