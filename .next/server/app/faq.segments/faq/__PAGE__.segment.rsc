8:["$","$L6",null,{"className":"leading-relaxed text-gray-600","children":"Absolutely. JOBR Kenya is completely free for job seekers. You can create an account, browse listings, apply for jobs, set up alerts, and upload your CV at no cost. We believe every Kenyan should have access to employment opportunities without financial barriers."}]
9:["$","section","Job Search & Alerts",{"children":[["$","div",null,{"className":"mb-4 flex items-center gap-3","children":[["$","div",null,{"className":"h-1 w-8 rounded-full bg-emerald-600"}],["$","h2",null,{"className":"text-xl font-bold text-gray-900","children":"Job Search & Alerts"}]]}],["$","div",null,{"className":"rounded-xl border border-gray-200/60 bg-white/70 p-6 backdrop-blur-sm sm:p-8","children":["$","$L3",null,{"type":"single","collapsible":true,"className":"w-full","children":[["$","$L4","0",{"value":"Job Search & Alerts-0","children":[["$","$L5",null,{"className":"text-left text-gray-800 hover:no-underline","children":"How do I search for jobs in my county?"}],["$","$L6",null,{"className":"leading-relaxed text-gray-600","children":"You can filter jobs by county in several ways. Use the county dropdown filter on the jobs page, browse our \"Jobs by County\" directory, or simply type your county name into the search bar (e.g., \"jobs in Mombasa\"). JOBR covers all 47 Kenyan counties, so you can find opportunities no matter where you are. You can also save your preferred county in your profile for faster future searches."}]]}],["$","$L4","1",{"value":"Job Search & Alerts-1","children":[["$","$L5",null,{"className":"text-left text-gray-800 hover:no-underline","children":"How do I create a job alert?"}],["$","$L6",null,{"className":"leading-relaxed text-gray-600","children":"To create a job alert, click on the \"Job Alerts\" section in your profile dashboard. Enter your preferred job title, category, location (county or city), and employment type. You can create multiple alerts for different preferences. Whenever new jobs matching your criteria are posted, you'll receive an email notification so you never miss an opportunity."}]]}],["$","$L4","2",{"value":"Job Search & Alerts-2","children":[["$","$L5",null,{"className":"text-left text-gray-800 hover:no-underline","children":"What types of opportunities do you list?"}],["$","$L6",null,{"className":"leading-relaxed text-gray-600","children":"JOBR Kenya lists a wide variety of opportunities including full-time and part-time jobs, internships, contract positions, freelance work, volunteer roles, government jobs (both national and county), tenders, scholarships, and career training programmes. We cover 49 job categories spanning industries like IT, healthcare, finance, education, engineering, hospitality, and more."}]]}]]}]}]]}]
a:["$","section","Profiles & Applications",{"children":[["$","div",null,{"className":"mb-4 flex items-center gap-3","children":[["$","div",null,{"className":"h-1 w-8 rounded-full bg-emerald-600"}],["$","h2",null,{"className":"text-xl font-bold text-gray-900","children":"Profiles & Applications"}]]}],["$","div",null,{"className":"rounded-xl border border-gray-200/60 bg-white/70 p-6 backdrop-blur-sm sm:p-8","children":["$","$L3",null,{"type":"single","collapsible":true,"className":"w-full","children":[["$","$L4","0",{"value":"Profiles & Applications-0","children":[["$","$L5",null,{"className":"text-left text-gray-800 hover:no-underline","children":"Can I upload my CV to JOBR?"}],["$","$L6",null,{"className":"leading-relaxed text-gray-600","children":"Yes. You can upload your CV in PDF, DOC, or DOCX format through your profile dashboard. We recommend keeping your CV updated with your latest qualifications, work experience, and skills. A well-maintained CV on JOBR makes it easier for employers to find you and for you to apply to listings quickly. You can also set your profile to \"Open to Opportunities\" to increase your visibility to recruiters."}]]}],["$","$L4","1",{"value":"Profiles & Applications-1","children":[["$","$L5",null,{"className":"text-left text-gray-800 hover:no-underline","children":"How do I track my job applications?"}],["$","$L6",null,{"className":"leading-relaxed text-gray-600","children":"All your job applications are tracked in your profile dashboard under \"My Applications.\" Here you can see the status of each application (submitted, viewed, shortlisted, or rejected), the date you applied, and the job details. If an employer responds, you'll receive an email notification and can continue the conversation through our messaging system."}]]}]]}]}]]}]
